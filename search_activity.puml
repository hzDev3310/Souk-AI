@startuml
skinparam style strictuml
title Product Search Workflow (with Semantic Search)

start

:User submits search request (query, filters, search_mode);
:Controller builds Base Query (applies price, category, store visibility filters);

if (search_mode == 'semantic' AND query is not empty?) then (yes)
  partition "ProductSemanticSearchService" {
    :Check if Embedding Service is Enabled;
    if (Enabled?) then (yes)
      :Execute Base Query to get Candidate Products;
      if (Candidates found?) then (yes)
        :Build Category Map for candidate products;
        
        partition "Ensure Embeddings" {
          :Load existing embeddings for candidate products;
          :Identify products with missing or outdated embeddings (Hash mismatch);
          if (Products need embedding?) then (yes)
            :Send product documents to Gemini API in chunks;
            :Save new embeddings to ProductSearchEmbedding table;
          else (no)
          endif
        }

        :Embed User Query via Gemini API;
        :Tokenize User Query;

        partition "Scoring and Filtering" {
          :For each candidate product:;
          :1. Calculate Cosine Similarity (Semantic Score);
          :2. Calculate Exact Match Ratio (Keyword Score);
          :3. Compute Final Score = (Semantic * 0.82) + (Keyword * 0.18);
          :Filter products with Final Score > 0.12;
          :Sort products by Final Score descending;
        }
        
        :Return Top Semantic Results;
      else (no)
        :Return Empty Collection;
      endif
    else (no)
      :Return Empty Collection;
    endif
  }

  if (Semantic Results not empty?) then (yes)
    :Paginate Semantic Results;
    :Render Search View;
    stop
  else (no)
  endif
else (no)
endif

partition "Fallback / Standard Search" {
  :Execute Standard Keyword Search;
  note right: Uses SQL LIKE on names\nand descriptions in EN/FR/AR
  :Paginate Standard Results;
}

:Render Search View;

stop
@enduml
